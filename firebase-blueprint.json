{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "technician"] }
      },
      "required": ["uid", "email"]
    },
    "TechnicalVisit": {
      "title": "Technical Visit",
      "description": "Information about a technical visit for installation or maintenance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "address": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "scheduledTime": { "type": "string" },
        "type": { "type": "string", "enum": ["CFTV", "Alarme", "Cerca Elétrica", "Motor de Portão", "Outros"] },
        "status": { "type": "string", "enum": ["Agendada", "Em Andamento", "Concluída", "Cancelada"] },
        "description": { "type": "string" },
        "observations": { "type": "string" },
        "technicianId": { "type": "string" },
        "technicianName": { "type": "string" },
        "totalValue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "date", "type", "status"]
    },
    "FinancialRecord": {
      "title": "Financial Record",
      "description": "Income or expense record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Receita", "Despesa"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "visitId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "value", "date"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Budget for approval",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pendente", "Aprovado", "Rejeitado"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "total", "status"]
    },
    "Client": {
      "title": "Client",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "type": { "type": "string", "enum": ["Avulso", "Contrato"] },
        "contractValue": { "type": "number" },
        "serviceSpecification": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type"]
    },
    "Receipt": {
      "title": "Receipt",
      "description": "Service receipt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "clientType": { "type": "string", "enum": ["Avulso", "Contrato"] },
        "serviceSpecification": { "type": "string" },
        "value": { "type": "number" },
        "referenceMonth": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["Dinheiro", "PIX", "Cartão"] },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "value", "date", "paymentMethod"]
    },
    "PixSettings": {
      "title": "PIX Settings",
      "description": "Global PIX payment information",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "bank": { "type": "string" },
        "favored": { "type": "string" },
        "document": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/visits/{visitId}": {
      "schema": "TechnicalVisit",
      "description": "Technical visits"
    },
    "/financial/{recordId}": {
      "schema": "FinancialRecord",
      "description": "Financial records"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Client budgets"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Customer database"
    },
    "/receipts/{receiptId}": {
      "schema": "Receipt",
      "description": "Generated receipts"
    },
    "/settings/pix": {
      "schema": "PixSettings",
      "description": "Global PIX configuration"
    }
  }
}
