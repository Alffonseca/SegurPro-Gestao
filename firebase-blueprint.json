{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "technician"] },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Company": {
      "title": "Company",
      "description": "Company account",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "TechnicalVisit": {
      "title": "Technical Visit",
      "description": "A technical service visit record",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "clientName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "scheduledTime": { "type": "string" },
        "expectedDate": { "type": "string", "format": "date-time" },
        "expectedTime": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "technicianId": { "type": "string" },
        "technicianName": { "type": "string" },
        "address": { "type": "string" },
        "description": { "type": "string" },
        "observations": { "type": "string" },
        "totalValue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "date", "status", "technicianId"]
    },
    "FinancialRecord": {
      "title": "Financial Record",
      "description": "Income or expense record",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "type": { "type": "string", "enum": ["Receita", "Despesa"] },
        "value": { "type": "number" },
        "description": { "type": "string" },
        "origin": { "type": "string", "description": "Origin of the record (e.g., Receipt number)" },
        "date": { "type": "string", "format": "date-time" },
        "clientId": { "type": "string" },
        "receiptId": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["Contrato", "Serviço Normal"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "value", "date"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Service budget for a client",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientEmail": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array" },
        "observations": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "total", "status"]
    },
    "Client": {
      "title": "Client",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "document": { "type": "string" },
        "type": { "type": "string", "enum": ["Avulso", "Contrato"] },
        "contractValue": { "type": "number" },
        "serviceSpecification": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type"]
    },
    "Receipt": {
      "title": "Receipt",
      "description": "Payment receipt",
      "type": "object",
      "properties": {
        "companyId": { "type": "string" },
        "number": { "type": "integer" },
        "clientName": { "type": "string" },
        "clientType": { "type": "string" },
        "value": { "type": "number" },
        "status": { "type": "string", "enum": ["Aguardando Pagamento", "Recebido"] },
        "paymentMethod": { "type": "string" },
        "referenceMonth": { "type": "string" },
        "serviceSpecification": { "type": "string" },
        "observations": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientName", "value", "status", "paymentMethod", "date"]
    },
    "GeneralSettings": {
      "title": "General Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/companies/{companyId}": { "schema": "Company", "description": "Company data" },
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/visits/{visitId}": { "schema": "TechnicalVisit", "description": "Technical visits" },
    "/financial/{recordId}": { "schema": "FinancialRecord", "description": "Financial transactions" },
    "/budgets/{budgetId}": { "schema": "Budget", "description": "Client budgets" },
    "/clients/{clientId}": { "schema": "Client", "description": "Client database" },
    "/receipts/{receiptId}": { "schema": "Receipt", "description": "Generated receipts" },
    "/settings/general": { "schema": "GeneralSettings", "description": "Global company settings" },
    "/settings/pix": { "schema": "object", "description": "PIX payment settings" }
  }
}
