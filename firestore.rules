rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // helpers
    function isSignedIn() { return request.auth != null; }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'emailparasiteslixo@gmail.com' || 
        request.auth.token.email.lower() == 'alffonseca42@gmail.com'
      );
    }

    function isMemberOf(companyId) {
      return isSignedIn() && (
        isSuperAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId
      );
    }

    function isAdminOf(companyId) {
      return isSignedIn() && (
        isSuperAdmin() || (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    // Main Collections
    function canUpdateWithToken(id) {
       let token = request.resource.data.clientSignatureToken;
       return token != null && 
              get(/databases/$(database)/documents/signature_requests/$(token)).data.documentId == id &&
              get(/databases/$(database)/documents/signature_requests/$(token)).data.status == 'signed';
    }

    match /signature_requests/{token} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if (resource.data.status == 'pending' && request.resource.data.status == 'signed') || 
                    (isSignedIn() && (isSuperAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId));
      allow delete: if isSignedIn() && (isSuperAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId);
    }

    match /companies/{companyId} {
      allow read: if isMemberOf(companyId);
      allow write: if isSuperAdmin() || (isMemberOf(companyId) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      match /{allSubcollections=**} {
        allow read, write: if isMemberOf(companyId);
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || 
                    request.auth.uid == userId || 
                    (isSignedIn() && isAdminOf(get(/databases/$(database)/documents/users/$(userId)).data.companyId));
      allow delete: if isSuperAdmin() || 
                    (isSignedIn() && isAdminOf(get(/databases/$(database)/documents/users/$(userId)).data.companyId));
    }

    // Main Collections
    match /clients/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId) || (
                    canUpdateWithToken(id) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt'])
                   );
    }

    match /visits/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId) || (
                    canUpdateWithToken(id) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt', 'clientSignatureDate'])
                   );
    }

    match /serviceOrders/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId) || (
                    canUpdateWithToken(id) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt'])
                   );
    }

    match /budgets/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId) || (
                    canUpdateWithToken(id) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt'])
                   );
    }

    match /financial/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId);
    }
    match /receipts/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId);
    }
    match /suppliers/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId);
    }

    match /logs/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /registration_codes/{id} {
      allow read: if isSignedIn();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        isSignedIn() && 
        resource.data.status == 'active' && 
        request.resource.data.status == 'used' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedAt', 'usedBy'])
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
