rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Helpers
    function isSignedIn() { return request.auth != null; }
    
    function isSuperAdmin() {
      return isSignedIn() && 
             request.auth.token != null && 
             'email' in request.auth.token && (
               request.auth.token.email.lower() == 'emailparasiteslixo@gmail.com' || 
               request.auth.token.email.lower() == 'alffonseca42@gmail.com'
             );
    }

    function isMemberOf(companyId) {
      return isSignedIn() && (
        isSuperAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId
        )
      );
    }

    function isAdminOf(companyId) {
      return isSignedIn() && (
        isSuperAdmin() || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner')
        )
      );
    }

    function canUpdateWithToken(docId, tokenId) {
       return tokenId != null && 
              exists(/databases/$(database)/documents/signature_requests/$(tokenId)) &&
              get(/databases/$(database)/documents/signature_requests/$(tokenId)).data.documentId == docId &&
              get(/databases/$(database)/documents/signature_requests/$(tokenId)).data.status == 'signed';
    }

    // 1. Signature Requests - Public Read for Portal
    match /signature_requests/{id} {
      allow read, get, list: if true;
      allow create: if isSignedIn();
      allow update: if (resource.data.status == 'pending' && request.resource.data.status == 'signed') || 
                    isSuperAdmin() || 
                    (isSignedIn() && isMemberOf(resource.data.companyId));
      allow delete: if isSuperAdmin() || (isSignedIn() && isMemberOf(resource.data.companyId));
    }

    // 1b. Signature Codes - Allows clients to get specific access codes directly by doc ID and update status
    match /signature_codes/{code} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if (resource.data.status == 'pending' && request.resource.data.status == 'signed') || 
                    isSuperAdmin() || 
                    (isSignedIn() && isMemberOf(resource.data.companyId));
      allow delete: if isSuperAdmin() || (isSignedIn() && isMemberOf(resource.data.companyId));
    }

    // 2. Business Collections
    match /companies/{companyId} {
      allow read, get, list: if true; // Allow public searching for invite codes and metadata
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || isAdminOf(companyId);
      
      match /{allSubcollections=**} {
        allow read, write: if isMemberOf(companyId);
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || 
                    request.auth.uid == userId || 
                    (isSignedIn() && isAdminOf(get(/databases/$(database)/documents/users/$(userId)).data.companyId));
      allow delete: if isSuperAdmin() || 
                    (isSignedIn() && isAdminOf(get(/databases/$(database)/documents/users/$(userId)).data.companyId));
    }

    match /clients/{id} {
      allow get: if true;
      allow list, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId) || (
                    canUpdateWithToken(id, request.resource.data.clientSignatureToken) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt'])
                   );
    }

    match /visits/{id} {
      allow get: if true;
      allow list, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId) || (
                    canUpdateWithToken(id, request.resource.data.clientSignatureToken) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt', 'clientSignatureDate'])
                   );
    }

    match /serviceOrders/{id} {
      allow get: if true;
      allow list, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId) || (
                    canUpdateWithToken(id, request.resource.data.clientSignatureToken) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt'])
                   );
    }

    match /budgets/{id} {
      allow get: if true;
      allow list, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId) || (
                    canUpdateWithToken(id, request.resource.data.clientSignatureToken) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt', 'status'])
                   );
    }

    match /financial/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId);
    }

    match /receipts/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId);
    }

    match /suppliers/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId);
    }

    match /inventory/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId);
    }

    match /inventoryTransactions/{id} {
      allow read, delete: if isMemberOf(resource.data.companyId);
      allow create: if isMemberOf(request.resource.data.companyId);
      allow update: if isMemberOf(resource.data.companyId);
    }

    match /logs/{id} {
      allow read: if isSignedIn() && (isSuperAdmin() || isAdminOf(resource.data.companyId));
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /registration_codes/{id} {
      allow read, get, list: if true; // Allow public validation of codes
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        isSignedIn() && 
        resource.data.status == 'active' && 
        request.resource.data.status == 'used' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'usedAt', 'usedBy'])
      );
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
