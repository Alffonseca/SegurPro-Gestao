rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && (request.auth.token.email == 'emailparasiteslixo@gmail.com' || request.auth.token.email == 'alffonseca42@gmail.com'); }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Multi-tenancy check
    function isMemberOf(companyId) {
      return isSignedIn() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId || isAdmin());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Companies
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Collections with companyId
    match /clients/{id} { allow read, write: if isMemberOf(incoming().companyId || existing().companyId); }
    match /visits/{id} { allow read, write: if isMemberOf(incoming().companyId || existing().companyId); }
    match /serviceOrders/{id} { allow read, write: if isMemberOf(incoming().companyId || existing().companyId); }
    match /budgets/{id} { allow read, write: if isMemberOf(incoming().companyId || existing().companyId); }
    match /financial/{id} { allow read, write: if isMemberOf(incoming().companyId || existing().companyId); }
    match /receipts/{id} { allow read, write: if isMemberOf(incoming().companyId || existing().companyId); }
    match /suppliers/{id} { allow read, write: if isMemberOf(incoming().companyId || existing().companyId); }

    // Signature Requests - PUBLIC ACCESS (The fix for 403)
    match /signature_requests/{token} {
      allow get: if true; 
      allow update: if (
        // Allow signature update
        incoming().diff(existing()).affectedKeys().hasOnly(['signature', 'status', 'signedAt', 'updatedAt']) &&
        incoming().status == 'signed' &&
        existing().status == 'pending'
      ) || isMemberOf(existing().companyId);
      allow create: if isMemberOf(incoming().companyId);
    }

    // Allow anonymous update for signature in specific collections
    match /visits/{id} {
      allow update: if !isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt']) &&
        incoming().clientSignatureToken != null &&
        get(/databases/$(database)/documents/signature_requests/$(incoming().clientSignatureToken)).data.documentId == id;
    }
    match /clients/{id} {
      allow update: if !isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt']) &&
        incoming().clientSignatureToken != null &&
        get(/databases/$(database)/documents/signature_requests/$(incoming().clientSignatureToken)).data.documentId == id;
    }
    match /serviceOrders/{id} {
      allow update: if !isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt']) &&
        incoming().clientSignatureToken != null &&
        get(/databases/$(database)/documents/signature_requests/$(incoming().clientSignatureToken)).data.documentId == id;
    }
    match /budgets/{id} {
      allow update: if !isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['clientSignature', 'clientSignatureToken', 'updatedAt']) &&
        incoming().clientSignatureToken != null &&
        get(/databases/$(database)/documents/signature_requests/$(incoming().clientSignatureToken)).data.documentId == id;
    }
  }
}
